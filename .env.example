# Database Configuration
DB_HOST=db
DB_PORT=5432
DB_NAME=vpn_db
DB_USER=postgres
DB_PASSWORD=change_me_in_production

# Bootstrap Admin Credentials (TEMPORARY - replace with service auth in production)
# WARNING: HTTP Basic Auth is only suitable for internal admin access with HTTPS
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production

# Application Environment: dev, staging, prod
ENVIRONMENT=dev

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# DEBUG - detailed debugging information
# INFO - confirmation of expected operation
# WARNING - something unexpected happened (default for production)
# ERROR - serious problem, application can continue
# CRITICAL - fatal error, application cannot continue
LOG_LEVEL=INFO

# Library logging level (for uvicorn, sqlalchemy, etc.): DEBUG, INFO, WARNING, ERROR, CRITICAL
# Libraries are noisy at DEBUG/INFO, so WARNING is recommended
LIBRARY_LOG_LEVEL=WARNING

# HAPP Crypto API endpoint for encrypting subscription links
HAPP_CRYPTO_API_URL=https://crypto.happ.su/api-v2.php

# Subscription base URL (the domain where subscription endpoints are accessible)
# Used to generate the subscription URL that will be encrypted via HAPP API
SUBSCRIPTION_BASE_URL=https://your-domain.com